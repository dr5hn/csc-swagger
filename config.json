{
  "openapi": "3.0.3",
  "info": {
    "title": "Country State City API",
    "description": "Geographic data API providing countries, states, and cities with tiered access levels.\n\n## Authentication\nAll endpoints require an API key passed via the `X-CSCAPI-KEY` header. Get your free key at [app.countrystatecity.in](https://app.countrystatecity.in).\n\n## Pricing & Limits\nThe fields returned, endpoints available, and request quotas depend on your plan. See current tiers and limits at:\n\n**[app.countrystatecity.in/pricing](https://app.countrystatecity.in/pricing)**\n\n## Data Access Levels\nEach plan includes a data access level that controls which fields are returned:\n\n- **Basic** — Core fields: id, name, iso2, iso3, phonecode, capital, currency, coordinates, region, timezones, emoji\n- **Coordinates** — Basic + extended metadata (population, tld, nationality, currency details, postal codes, etc.)\n- **Full** — All fields including translations (18+ languages) and wikiDataId\n\nFields restricted to higher tiers are marked in each schema below.\n\n## Feature Gating\nSome endpoints require a minimum tier. Restricted endpoints return `403` with an `upgradeUrl` when accessed on a lower plan. Check the [pricing page](https://app.countrystatecity.in/pricing) for current feature availability.\n\n## Rate Limiting\nRequests exceeding your daily or monthly quota receive a `429` response with your current limit, period, tier, and an upgrade URL.\n\n## Caching\nAll responses include `Cache-Control`, `ETag`, and `X-Cache` (HIT/MISS) headers. Use `If-None-Match` for conditional requests to receive `304 Not Modified`.",
    "contact": {
      "name": "Darshan Gada (dr5hn)",
      "email": "gadadarshan@gmail.com",
      "url": "https://countrystatecity.in"
    },
    "license": {
      "name": "Creative Commons Attribution 4.0",
      "url": "https://creativecommons.org/licenses/by/4.0/"
    },
    "version": "2.2.0"
  },
  "servers": [
    {
      "url": "https://api.countrystatecity.in/v1",
      "description": "Production API"
    }
  ],
  "tags": [
    {
      "name": "Countries",
      "description": "Country data — 250+ countries with metadata, coordinates, and translations"
    },
    {
      "name": "States",
      "description": "State/province/region data — 5,000+ subdivisions"
    },
    {
      "name": "Cities",
      "description": "City data — 150,000+ cities worldwide"
    },
    {
      "name": "Regions",
      "description": "Geographic regions and subregions — continental groupings of countries"
    }
  ],
  "paths": {
    "/countries": {
      "get": {
        "tags": ["Countries"],
        "summary": "Get all countries",
        "description": "Returns a list of all countries. Fields returned depend on your plan's data access level.\n\n**Availability:** All tiers",
        "operationId": "getCountries",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "description": "Search filter. Case-insensitive match on `name` and `native` fields. Min 2 characters. **Requires Supporter+ plan.**",
            "required": false,
            "schema": { "type": "string", "minLength": 2, "maxLength": 100, "example": "india" }
          }
        ],
        "responses": {
          "200": {
            "description": "List of countries",
            "headers": {
              "Cache-Control": { "$ref": "#/components/headers/CacheControl" },
              "ETag": { "$ref": "#/components/headers/ETag" },
              "X-Cache": { "$ref": "#/components/headers/XCache" }
            },
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Country" }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "429": { "$ref": "#/components/responses/RateLimited" }
        },
        "security": [{ "ApiKeyAuth": [] }]
      }
    },
    "/countries/{ciso}": {
      "get": {
        "tags": ["Countries"],
        "summary": "Get country by ISO2 code or ID",
        "description": "Returns detailed information for a single country. Accepts ISO2 code (e.g., `IN`, `US`) or numeric ID.\n\n**Availability:** All tiers",
        "operationId": "getCountry",
        "parameters": [
          {
            "name": "ciso",
            "in": "path",
            "description": "ISO2 code (e.g., `IN`) or numeric ID of the country",
            "required": true,
            "schema": { "type": "string", "example": "IN" }
          }
        ],
        "responses": {
          "200": {
            "description": "Country details",
            "headers": {
              "Cache-Control": { "$ref": "#/components/headers/CacheControl" },
              "ETag": { "$ref": "#/components/headers/ETag" },
              "X-Cache": { "$ref": "#/components/headers/XCache" }
            },
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Country" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "429": { "$ref": "#/components/responses/RateLimited" }
        },
        "security": [{ "ApiKeyAuth": [] }]
      }
    },
    "/countries/{ciso}/states": {
