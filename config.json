  "components": {
    "schemas": {
      "Country": {
        "type": "object",
        "description": "Country object. Fields returned depend on your plan's data access level.",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "description": "Unique identifier",
            "example": 101
          },
          "name": {
            "type": "string",
            "description": "Country name in English",
            "example": "India"
          },
          "iso2": {
            "type": "string",
            "description": "ISO 3166-1 alpha-2 code",
            "example": "IN"
          },
          "iso3": {
            "type": "string",
            "description": "ISO 3166-1 alpha-3 code",
            "example": "IND"
          },
          "phonecode": {
            "type": "string",
            "description": "International dialling code",
            "example": "91"
          },
          "capital": {
            "type": "string",
            "nullable": true,
            "description": "Capital city name",
            "example": "New Delhi"
          },
          "currency": {
            "type": "string",
            "nullable": true,
            "description": "Currency code",
            "example": "INR"
          },
          "native": {
            "type": "string",
            "nullable": true,
            "description": "Country name in native language",
            "example": "\u092d\u093e\u0930\u0924"
          },
          "emoji": {
            "type": "string",
            "nullable": true,
            "description": "Flag emoji",
            "example": "\ud83c\uddee\ud83c\uddf3"
          },
          "latitude": {
            "type": "string",
            "nullable": true,
            "description": "Latitude coordinate",
            "example": "20.00000000"
          },
          "longitude": {
            "type": "string",
            "nullable": true,
            "description": "Longitude coordinate",
            "example": "77.00000000"
          },
          "region": {
            "type": "string",
            "nullable": true,
            "description": "Geographic region",
            "example": "Asia"
          },
          "region_id": {
            "type": "integer",
            "nullable": true,
            "description": "Region identifier"
          },
          "subregion": {
            "type": "string",
            "nullable": true,
            "description": "Geographic subregion",
            "example": "Southern Asia"
          },
          "subregion_id": {
            "type": "integer",
            "nullable": true,
            "description": "Subregion identifier"
          },
          "timezones": {
            "type": "string",
            "nullable": true,
            "description": "JSON string of timezone objects with zoneName, gmtOffset, gmtOffsetName, abbreviation, tzName",
            "example": "[{\"zoneName\":\"Asia/Kolkata\",\"gmtOffset\":19800,\"gmtOffsetName\":\"UTC+05:30\",\"abbreviation\":\"IST\",\"tzName\":\"Indian Standard Time\"}]"
          },
          "numeric_code": {
            "type": "string",
            "nullable": true,
            "description": "ISO 3166-1 numeric code. **Coordinates tier and above.**",
            "example": "356"
          },
          "currency_name": {
            "type": "string",
            "nullable": true,
            "description": "Full currency name. **Coordinates tier and above.**",
            "example": "Indian rupee"
          },
          "currency_symbol": {
            "type": "string",
            "nullable": true,
            "description": "Currency symbol. **Coordinates tier and above.**",
            "example": "\u20b9"
          },
          "tld": {
            "type": "string",
            "nullable": true,
            "description": "Top-level domain. **Coordinates tier and above.**",
            "example": ".in"
          },
          "nationality": {
            "type": "string",
            "nullable": true,
            "description": "Nationality/demonym. **Coordinates tier and above.**",
            "example": "Indian"
          },
          "population": {
            "type": "integer",
            "format": "int64",
            "nullable": true,
            "description": "Population count. **Coordinates tier and above.**"
          },
          "gdp": {
            "type": "integer",
            "format": "int64",
            "nullable": true,
            "description": "Gross domestic product (USD). **Coordinates tier and above.**"
          },
          "area_sq_km": {
            "type": "number",
            "nullable": true,
            "description": "Area in square kilometres. **Coordinates tier and above.**"
          },
          "postal_code_format": {
            "type": "string",
            "nullable": true,
            "description": "Postal code format pattern. **Coordinates tier and above.**"
          },
          "postal_code_regex": {
