    "responses": {
      "Unauthorized": {
        "description": "Missing or invalid API key",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" },
            "example": { "error": "Unauthorized. You shouldn't be here." }
          }
        }
      },
      "NotFound": {
        "description": "Resource not found",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" },
            "example": { "error": "Country not found." }
          }
        }
      },
      "FeatureRestricted": {
        "description": "Feature not available on your current plan. Upgrade to access this endpoint.",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/FeatureError" },
            "example": {
              "error": "This feature is not available on your current plan.",
              "feature": "bulkStates",
              "upgradeUrl": "https://app.countrystatecity.in/pricing"
            }
          }
        }
      },
      "RateLimited": {
        "description": "Daily or monthly usage limit exceeded",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/RateLimitError" },
            "example": {
              "error": "Daily usage limit exceeded. Please try again tomorrow or contact support for higher limits.",
              "limit": 100,
              "period": "daily",
              "tier": "community",
              "upgradeUrl": "https://app.countrystatecity.in/pricing"
            }
          }
        }
      }
    },
    "headers": {
      "CacheControl": {
        "description": "Cache directive",
        "schema": { "type": "string", "example": "public, max-age=3600" }
      },
      "ETag": {
        "description": "Entity tag for conditional requests (use with `If-None-Match`)",
        "schema": { "type": "string", "example": "\"a3f2b8c1d4e5f6a7b8c9d0e1f2a3b4c5\"" }
      },
      "XCache": {
        "description": "Whether the response was served from cache",
        "schema": { "type": "string", "enum": ["HIT", "MISS"], "example": "HIT" }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "description": "API key for authentication. Get your free key at [app.countrystatecity.in](https://app.countrystatecity.in).",
        "name": "X-CSCAPI-KEY",
        "in": "header"
      }
    }
  }
